{
	"name": "@repo/workers",
	"type": "module",
	"main": "./index.ts",
	"scripts": {
		"build": "tsup ./modules --format esm --clean",
		"dev:deploy": "pm2 start ./ecosystem.config.cjs",
		"dev:build": "tsup ./modules --format esm --watch",
		"dev:all": "run-p dev:build dev:deploy",
		"dev": "run-s build dev:all",
		"postinstall": "run-p build",
		"clean": "rimraf node_modules"
	},
	"dependencies": {
		"chokidar": "^4.0.1",
		"file-type": "^19.6.0",
		"nats": "^2.28.2",
		"prisma-client-js": "workspace:*"
	}
}
